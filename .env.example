# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Auth
NEXTAUTH_SECRET=generate-a-random-secret-here
NEXTAUTH_URL=https://your-app.vercel.app

# Supabase (optional, if using Supabase client)
NEXT_PUBLIC_SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=[YOUR-ANON-KEY]

# Solana RPC (get from Helius, QuickNode, or Alchemy)
NEXT_PUBLIC_SOLANA_RPC=https://mainnet.helius-rpc.com/?api-key=[YOUR-HELIUS-KEY]

# Birdeye API (get from https://birdeye.so)
BIRDEYE_API_KEY=[YOUR-BIRDEYE-KEY]

# Helius API (get from https://helius.dev)
HELIUS_API_KEY=[YOUR-HELIUS-KEY]
